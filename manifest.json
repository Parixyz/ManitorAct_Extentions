{
  "manifest_version": 3,
  "name": "Activity Cluster Graph",
  "version": "1.1.0",
  "description": "Tracks browser activity, classifies it with NLP, and visualizes semantic clusters.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Activity Cluster Graph"
  }
}
